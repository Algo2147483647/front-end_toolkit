{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/asset-dashboard/asset-snapshot.schema.json",
  "title": "Global Asset Snapshot",
  "type": "object",
  "required": ["meta", "settings", "accounts", "fxRates", "quotes", "assets"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["schemaVersion", "title", "updatedAt"],
      "properties": {
        "schemaVersion": { "type": "string" },
        "title": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    },
    "settings": {
      "type": "object",
      "required": ["baseCurrency", "supportedBaseCurrencies", "locale"],
      "properties": {
        "baseCurrency": { "type": "string" },
        "supportedBaseCurrencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "locale": { "type": "string" }
      },
      "additionalProperties": true
    },
    "accounts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "defaultCurrency", "updatedAt"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "institution": { "type": "string" },
          "type": { "type": "string" },
          "defaultCurrency": { "type": "string" },
          "country": { "type": "string" },
          "notes": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "fxRates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "currency", "rateFromUsd", "updatedAt"],
        "properties": {
          "id": { "type": "string" },
          "currency": { "type": "string" },
          "rateFromUsd": { "type": "number" },
          "notes": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "quotes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "symbol", "name", "assetType", "quoteCurrency", "price", "updatedAt"],
        "properties": {
          "id": { "type": "string" },
          "symbol": { "type": "string" },
          "name": { "type": "string" },
          "assetType": { "type": "string" },
          "market": { "type": "string" },
          "unit": { "type": "string" },
          "quoteCurrency": { "type": "string" },
          "price": { "type": "number" },
          "notes": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "name", "accountId", "updatedAt"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "name": { "type": "string" },
          "accountId": { "type": "string" },
          "currency": { "type": "string" },
          "amount": { "type": "number" },
          "quoteId": { "type": "string" },
          "quantity": { "type": "number" },
          "holdingType": { "type": "string" },
          "storageLocation": { "type": "string" },
          "notes": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
